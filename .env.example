APP_NAME=Wasel Palestine API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
ALGORITHM=HS256
DATABASE_URL=postgresql+psycopg://wasel:wasel@db:5432/wasel_db
AUTO_CREATE_TABLES=true
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]
SEED_ADMIN_EMAIL=admin@wasel.local
SEED_ADMIN_PASSWORD=Admin#12345
SEED_ADMIN_FULL_NAME=Platform Admin
EXTERNAL_REQUEST_TIMEOUT_SECONDS=8
EXTERNAL_MAX_RETRIES=3
EXTERNAL_BACKOFF_BASE_SECONDS=0.5
EXTERNAL_BACKOFF_MAX_SECONDS=4
EXTERNAL_USER_AGENT=WaselPalestine/1.0 (academic-project)

ROUTING_PROVIDER=osm
ROUTING_BASE_URL=https://router.project-osrm.org
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
ROUTING_MIN_INTERVAL_MS=1200

WEATHER_PROVIDER=openweather
WEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
# Required for /api/v1/weather/current (without it the API responds with HTTP 503 SERVICE_NOT_CONFIGURED).
WEATHER_API_KEY=
WEATHER_MIN_INTERVAL_MS=300

CACHE_TTL_ROUTE_SECONDS=120
CACHE_TTL_GEOCODE_SECONDS=600
CACHE_TTL_WEATHER_SECONDS=300
